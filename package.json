{
  "name": "lyra",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Local, TUI live-coding music environment built on Strudel's pattern engine + superdough, running headless on node-web-audio-api.",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "lyra": "bin/lyra.mjs"
  },
  "scripts": {
    "spike": "node scripts/run.mjs tsx src/spike/oscillator.ts",
    "spike:superdough": "node scripts/run.mjs tsx src/spike/superdough.ts",
    "spike:strudel": "node scripts/run.mjs tsx src/spike/strudel.ts",
    "spike:repl": "node scripts/run.mjs tsx src/spike/repl.ts",
    "spike:samples": "node scripts/run.mjs tsx src/spike/samples.ts",
    "spike:rec": "node scripts/run.mjs tsx src/spike/rec.ts",
    "spike:electron": "node spike/electron/run.mjs",
    "spike:electron:test": "node spike/electron/run.mjs --autotest",
    "start": "node scripts/run.mjs tsx src/main.tsx",
    "dev": "node scripts/run.mjs tsx watch src/main.tsx",
    "gui": "node scripts/gui.mjs",
    "build:renderer": "vite build --config src/renderer/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/fix-deps.mjs"
  },
  "dependencies": {
    "@strudel/core": "^1.1.0",
    "@strudel/mini": "^1.1.0",
    "@strudel/transpiler": "^1.1.0",
    "ink": "^7.1.0",
    "node-web-audio-api": "^1.0.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "superdough": "^1.1.0"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/view": "^6.43.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "codemirror": "^6.0.2",
    "electron": "^42.4.1",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.5"
  }
}
